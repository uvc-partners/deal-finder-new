# MongoDB
MONGO_URI=
MONGO_DB_NAME=
MONGO_DB_COLLECTION_NAME=
IO_COLLECTION_NAME=
RECOMMENDATION_STACK_COLLECTION_NAME=

# Google Sheets
GOOGLE_SHEETS_TEMPLATE_ID=
GOOGLE_SHEETS_DESTINATION_FOLDER_ID=

# Email (Gmail SMTP for sending reports)
EMAIL_SENDER=
EMAIL_APP_PASSWORD=

# Google auth: "oauth" (recommended) or "service_account"
# Use OAuth when copying to a folder in "My Drive" (avoids storageQuotaExceeded
# with new service accounts that cannot own Drive items after April 2025).
GOOGLE_AUTH_MODE=oauth

# OAuth (when GOOGLE_AUTH_MODE=oauth) - base64-encoded JSON
# Get client secrets: Download from Google Cloud Console > Credentials > OAuth client ID (Desktop)
#   base64 -i path/to/client_secrets.json | tr -d '\n'
# Get token: Run `python scripts/setup_google_oauth.py` - it will print OAUTH_TOKEN_B64
GOOGLE_OAUTH_CLIENT_SECRETS_B64=
GOOGLE_OAUTH_TOKEN_B64=

# Service account (when GOOGLE_AUTH_MODE=service_account)
# Only use with Shared Drives or domain-wide delegation (impersonate_user)
# SERVICE_ACCOUNT_B64=   # base64 of service account JSON
# GOOGLE_IMPERSONATE_USER=dt@uvcpartners.com
